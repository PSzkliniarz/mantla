---
---

<section id="services" class="py-20 bg-[#f4f6f8]">
	<div class="max-w-6xl mx-auto px-4">
		<div class="text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#222222]">
				Nasze Usługi
			</h2>
			<div class="w-24 h-1 bg-[#0ea5c6] rounded-full mx-auto mb-6"></div>
			<p class="text-lg text-[#222222] max-w-3xl mx-auto leading-relaxed">
				Oferujemy szeroki zakres usług alpinistycznych dla przemysłu. Każde zlecenie realizujemy
				z najwyższą starannością, stosując najnowsze standardy bezpieczeństwa.
			</p>
		</div>
		
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
			<div class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 overflow-hidden border border-[#dddddd]">
				<div class="bg-[#0ea5c6] h-2"></div>
				<div class="p-8">
					<div class="w-16 h-16 bg-[#f4f6f8] border-2 border-[#0ea5c6] rounded-full flex items-center justify-center mb-6 group-hover:bg-[#0ea5c6] transition-colors duration-300">
						<span class="text-2xl group-hover:text-white transition-colors">🏗️</span>
					</div>
					<h3 class="text-xl font-bold text-[#222222] mb-4">Montaż konstrukcji</h3>
					<p class="text-[#222222] leading-relaxed">Montaż konstrukcji stalowych, reklamowych i przemysłowych na wysokościach z pełnym bezpieczeństwem</p>
				</div>
			</div>
			
			<div class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 overflow-hidden border border-[#dddddd]">
				<div class="bg-[#0ea5c6] h-2"></div>
				<div class="p-8">
					<div class="w-16 h-16 bg-[#f4f6f8] border-2 border-[#0ea5c6] rounded-full flex items-center justify-center mb-6 group-hover:bg-[#0ea5c6] transition-colors duration-300">
						<span class="text-2xl group-hover:text-white transition-colors">🧹</span>
					</div>
					<h3 class="text-xl font-bold text-[#222222] mb-4">Mycie i czyszczenie</h3>
					<p class="text-[#222222] leading-relaxed">Profesjonalne mycie fasad, okien i powierzchni szklanych budynków z wykorzystaniem technik alpinistycznych</p>
				</div>
			</div>
			
			<div class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 overflow-hidden border border-[#dddddd]">
				<div class="bg-[#0ea5c6] h-2"></div>
				<div class="p-8">
					<div class="w-16 h-16 bg-[#f4f6f8] border-2 border-[#0ea5c6] rounded-full flex items-center justify-center mb-6 group-hover:bg-[#0ea5c6] transition-colors duration-300">
						<span class="text-2xl group-hover:text-white transition-colors">🔧</span>
					</div>
					<h3 class="text-xl font-bold text-[#222222] mb-4">Konserwacja</h3>
					<p class="text-[#222222] leading-relaxed">Przeglądy i konserwacja obiektów przemysłowych i budynków na wysokościach</p>
				</div>
			</div>
			
			<div class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 overflow-hidden border border-[#dddddd]">
				<div class="bg-[#0ea5c6] h-2"></div>
				<div class="p-8">
					<div class="w-16 h-16 bg-[#f4f6f8] border-2 border-[#0ea5c6] rounded-full flex items-center justify-center mb-6 group-hover:bg-[#0ea5c6] transition-colors duration-300">
						<span class="text-2xl group-hover:text-white transition-colors">⚡</span>
					</div>
					<h3 class="text-xl font-bold text-[#222222] mb-4">Prace elektryczne</h3>
					<p class="text-[#222222] leading-relaxed">Instalacja i konserwacja oświetlenia, instalacji elektrycznych na wysokości</p>
				</div>
			</div>
			
			<div class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 overflow-hidden border border-[#dddddd]">
				<div class="bg-[#0ea5c6] h-2"></div>
				<div class="p-8">
					<div class="w-16 h-16 bg-[#f4f6f8] border-2 border-[#0ea5c6] rounded-full flex items-center justify-center mb-6 group-hover:bg-[#0ea5c6] transition-colors duration-300">
						<span class="text-2xl group-hover:text-white transition-colors">🎨</span>
					</div>
					<h3 class="text-xl font-bold text-[#222222] mb-4">Malowanie</h3>
					<p class="text-[#222222] leading-relaxed">Malowanie konstrukcji, fasad i elementów budynków na wysokościach</p>
				</div>
			</div>
			
			<div class="group bg-white rounded-xl shadow-lg hover:shadow-2xl transition-all duration-500 transform hover:-translate-y-2 overflow-hidden border border-[#dddddd]">
				<div class="bg-[#0ea5c6] h-2"></div>
				<div class="p-8">
					<div class="w-16 h-16 bg-[#f4f6f8] border-2 border-[#0ea5c6] rounded-full flex items-center justify-center mb-6 group-hover:bg-[#0ea5c6] transition-colors duration-300">
						<span class="text-2xl group-hover:text-white transition-colors">📡</span>
					</div>
					<h3 class="text-xl font-bold text-[#222222] mb-4">Instalacje techniczne</h3>
					<p class="text-[#222222] leading-relaxed">Montaż anten, kamer i innych urządzeń technicznych na wysokości</p>
				</div>
			</div>
		</div>
	</div>
</section>
