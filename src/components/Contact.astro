<section id="contact" class="py-16 bg-gray-50">
	<div class="max-w-6xl mx-auto px-4">
		<h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-4">
			Skontaktuj się z nami
		</h2>
		<p class="text-lg text-center text-gray-600 max-w-3xl mx-auto mb-12 leading-relaxed">
			Jeśli potrzebujesz profesjonalnych usług alpinistycznych, skontaktuj się z nami. 
			Oferujemy darmowe konsultacje i wyceny, dostosowane do indywidualnych potrzeb klienta.
		</p>
		
		<div class="bg-white rounded-lg shadow-lg p-8 max-w-2xl mx-auto">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
				<div class="text-center">
					<div class="text-3xl mb-3">📧</div>
					<h3 class="font-semibold text-gray-900 mb-2">Email</h3>
					<p class="text-gray-600">kontakt@alpinistyka.pl</p>
				</div>
				
				<div class="text-center">
					<div class="text-3xl mb-3">📞</div>
					<h3 class="font-semibold text-gray-900 mb-2">Telefon</h3>
					<p class="text-gray-600">+48 123 456 789</p>
				</div>
			</div>
			
			<div class="text-center">
				<div class="text-3xl mb-3">📍</div>
				<h3 class="font-semibold text-gray-900 mb-2">Siedziba firmy</h3>
				<p class="text-gray-600">ul. Przemysłowa 123<br>00-000 Warszawa<br>Polska</p>
			</div>
			
			<div class="mt-8 text-center">
				<p class="text-gray-600 mb-4">Działamy na terenie całej Polski!</p>
				<div class="flex justify-center gap-4">
					<span class="text-2xl">⏰</span>
					<p class="text-gray-600">Pon-Pt: 8:00 - 18:00<br>Sob: 9:00 - 14:00</p>
				</div>
			</div>
		</div>
	</div>
</section>
