---
import Map from './Map.astro';
---

<section id="contact" class="py-20 bg-white">
	<div class="max-w-6xl mx-auto px-4">
		<!-- Header -->
		<div class="text-center mb-16">
			<h2 class="text-4xl md:text-5xl font-bold mb-4 text-[#222222]">
				Skontaktuj się z nami
			</h2>
			<div class="w-24 h-1 bg-[#0ea5c6] rounded-full mx-auto mb-6"></div>
			<p class="text-lg text-[#222222] max-w-3xl mx-auto leading-relaxed">
				Jeśli potrzebujesz profesjonalnych usług alpinistycznych, skontaktuj się z nami. 
				Oferujemy darmowe konsultacje i wyceny, dostosowane do indywidualnych potrzeb klienta.
			</p>
		</div>
		
		<!-- Contact cards and map -->
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
			<!-- Contact information -->
			<div class="space-y-6">
				<!-- Email card -->
				<div class="bg-[#f4f6f8] border border-[#dddddd] rounded-xl p-6 hover:shadow-lg transition-all duration-300">
					<div class="flex items-center space-x-4">
						<div class="flex-shrink-0 w-12 h-12 bg-[#0ea5c6] rounded-lg flex items-center justify-center">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
							</svg>
						</div>
						<div>
							<h3 class="font-semibold text-[#222222] text-lg">Email</h3>
							<a href="mailto:kontakt@alpinistyka.pl" class="text-[#0ea5c6] hover:text-[#0a8ca6] transition-colors no-underline">
								mantlakontakt@gmail.com
							</a>
						</div>
					</div>
				</div>
				
				<!-- Phone card -->
				<div class="bg-[#f4f6f8] border border-[#dddddd] rounded-xl p-6 hover:shadow-lg transition-all duration-300">
					<div class="flex items-center space-x-4">
						<div class="flex-shrink-0 w-12 h-12 bg-[#0ea5c6] rounded-lg flex items-center justify-center">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
							</svg>
						</div>
						<div>
							<h3 class="font-semibold text-[#222222] text-lg">Telefon</h3>
							<a href="tel:+48123456789" class="text-[#0ea5c6] hover:text-[#0a8ca6] transition-colors no-underline">
								+48 720 835 739
							</a>
						</div>
					</div>
				</div>
				
				<!-- Service area info -->
				<div class="bg-[#0ea5c6] rounded-xl p-6 text-white">
					<div class="flex items-center space-x-3 mb-3">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
						</svg>
						<h3 class="font-semibold text-lg">Obszar działania</h3>
					</div>
					<p class="text-white/90">
						Działamy w promieniu 100 km od naszej lokalizacji w Kielcach. 
						Sprawdź mapę, aby zobaczyć czy obsługujemy Twój obszar.
					</p>
				</div>
				
			
			</div>
			
			<!-- Map -->
			<div class="lg:col-span-1">
				<div class="bg-[#f4f6f8] border border-[#dddddd] rounded-xl p-6">
					<h3 class="font-semibold text-[#222222] text-lg mb-4">Nasza lokalizacja</h3>
					<Map client:load />
				</div>
			</div>
		</div>
	</div>
</section>
