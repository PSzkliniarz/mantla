				</div>
			</div>
			
			<div class="bg-gray-50 border-2 border-dashed border-gray-300 rounded-lg p-8 hover:border-blue-500 transition-all duration-300 hover:shadow-lg">
				<div class="text-center">
					<div class="w-full h-48 bg-gray-200 rounded-lg mb-4 flex items-center justify-center">
						<span class="text-6xl">🏨</span>
					</div>
					<h3 class="text-xl font-semibold text-gray-900 mb-3">Hotel Pięciogwiazdkowy</h3>
