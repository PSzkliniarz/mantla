---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Mantla - Profesjonalne Usługi Alpinistyczne na Wysokościach</title>
	</head>
	<body class="bg-[#f4f6f8]">
		<nav class="bg-white shadow-lg sticky top-0 z-50 border-b border-[#dddddd]">
			<div class="max-w-6xl mx-auto px-4">
				<div class="flex justify-between items-center py-4">
					<a href="/" class="flex items-center text-2xl font-bold text-[#0ea5c6] hover:text-[#0a8ca6] transition-colors duration-300">
						<Image src={logo} alt="Mantla Logo" height={64} class="h-16 w-auto" />
					</a>
					
					<!-- Desktop Menu -->
					<ul class="hidden md:flex space-x-8">
						<li><a href="#hero" class="text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300 relative group">
							Start
							<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#0ea5c6] transition-all duration-300 group-hover:w-full"></span>
						</a></li>
						<li><a href="#about" class="text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300 relative group">
							O nas
							<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#0ea5c6] transition-all duration-300 group-hover:w-full"></span>
						</a></li>
						<li><a href="#services" class="text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300 relative group">
							Usługi
							<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#0ea5c6] transition-all duration-300 group-hover:w-full"></span>
						</a></li>
						<li><a href="#projects" class="text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300 relative group">
							Realizacje
							<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#0ea5c6] transition-all duration-300 group-hover:w-full"></span>
						</a></li>
						<li><a href="#contact" class="text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300 relative group">
							Kontakt
							<span class="absolute bottom-0 left-0 w-0 h-0.5 bg-[#0ea5c6] transition-all duration-300 group-hover:w-full"></span>
						</a></li>
					</ul>
					
					<!-- Mobile Menu Button -->
					<button 
						id="mobile-menu-button" 
						class="md:hidden flex flex-col justify-center items-center w-8 h-8 space-y-1.5 focus:outline-none"
						aria-label="Toggle mobile menu"
					>
						<span class="block w-6 h-0.5 bg-[#222222] transition-all duration-300 origin-center"></span>
						<span class="block w-6 h-0.5 bg-[#222222] transition-all duration-300 origin-center"></span>
						<span class="block w-6 h-0.5 bg-[#222222] transition-all duration-300 origin-center"></span>
					</button>
				</div>
				
				<!-- Mobile Menu -->
				<div id="mobile-menu" class="hidden md:hidden pb-4">
					<ul class="flex flex-col space-y-2">
						<li><a href="#hero" class="block py-2 text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300">
							Start
						</a></li>
						<li><a href="#about" class="block py-2 text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300">
							O nas
						</a></li>
						<li><a href="#services" class="block py-2 text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300">
							Usługi
						</a></li>
						<li><a href="#projects" class="block py-2 text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300">
							Realizacje
						</a></li>
						<li><a href="#contact" class="block py-2 text-[#222222] hover:text-[#0ea5c6] font-semibold transition-colors duration-300">
							Kontakt
						</a></li>
					</ul>
				</div>
			</div>
		</nav>
		
		<main>
			<slot />
		</main>
		
		<footer class="bg-[#111111] text-white py-12">
			<div class="max-w-6xl mx-auto px-4">
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div>
						<div class="flex items-center space-x-2 mb-4">
							<Image src={logo} alt="Mantla Logo" width={24} height={24} class="h-6 w-auto" />
							<h3 class="text-xl font-bold">Mantla</h3>
						</div>
						<p class="text-gray-300 text-sm leading-relaxed">
							Profesjonalna alpinistyka przemysłowa - bezpieczeństwo i jakość na pierwszym miejscu
						</p>
					</div>
					
					<div>
						<h4 class="text-lg font-semibold mb-4 text-[#0ea5c6]">Szybkie linki</h4>
						<ul class="space-y-2">
							<li><a href="#about" class="text-gray-300 hover:text-[#0ea5c6] transition-colors">O nas</a></li>
							<li><a href="#services" class="text-gray-300 hover:text-[#0ea5c6] transition-colors">Usługi</a></li>
							<li><a href="#projects" class="text-gray-300 hover:text-[#0ea5c6] transition-colors">Realizacje</a></li>
							<li><a href="#contact" class="text-gray-300 hover:text-[#0ea5c6] transition-colors">Kontakt</a></li>
						</ul>
					</div>
					
					<div>
						<h4 class="text-lg font-semibold mb-4 text-[#0ea5c6]">Kontakt</h4>
						<div class="space-y-2 text-gray-300">
							<p class="flex items-center space-x-2">
								<span>📧</span>
								<span>mantlakontakt@gmail.com</span>
							</p>
							<p class="flex items-center space-x-2">
								<span>📞</span>
								<span>+48 720 835 739</span>
							</p>
							<p class="flex items-center space-x-2">
								<span>📍</span>
								<span>Kielce, Polska</span>
							</p>
						</div>
					</div>
				</div>
				
				<div class="border-t border-[#222222] mt-8 pt-8 text-center">
					<p class="text-gray-300 text-sm">&copy; 2026 Mantla. Wszystkie prawa zastrzeżone.</p>
				</div>
			</div>
		</footer>
	</body>
</html>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const mobileMenuButton = document.getElementById('mobile-menu-button');
		const mobileMenu = document.getElementById('mobile-menu');
		
		// Check if elements exist before using them
		if (!mobileMenuButton || !mobileMenu) return;
		
		const buttonSpans = mobileMenuButton.querySelectorAll('span');
		
		mobileMenuButton.addEventListener('click', () => {
			// Toggle menu visibility
			mobileMenu.classList.toggle('hidden');
			
			// Animate hamburger to X
			if (buttonSpans[0]) {
				buttonSpans[0].classList.toggle('rotate-45');
				buttonSpans[0].classList.toggle('translate-y-2');
			}
			if (buttonSpans[1]) {
				buttonSpans[1].classList.toggle('opacity-0');
			}
			if (buttonSpans[2]) {
				buttonSpans[2].classList.toggle('-rotate-45');
				buttonSpans[2].classList.toggle('-translate-y-2');
			}
		});
		
		// Close menu when clicking on links
		const mobileLinks = mobileMenu.querySelectorAll('a');
		mobileLinks.forEach(link => {
			link.addEventListener('click', () => {
				mobileMenu.classList.add('hidden');
				// Reset hamburger animation
				if (buttonSpans[0]) {
					buttonSpans[0].classList.remove('rotate-45', 'translate-y-2');
				}
				if (buttonSpans[1]) {
					buttonSpans[1].classList.remove('opacity-0');
				}
				if (buttonSpans[2]) {
					buttonSpans[2].classList.remove('-rotate-45', '-translate-y-2');
				}
			});
		});
	});
</script>

<style>
	@import "../styles/global.css";
</style>

